rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'phoneNumber', 'loginPassword', 'withdrawalPassword', 'createdAt']) &&
             data.keys().size() >= 5 &&
             data.uid is string &&
             data.phoneNumber is string && data.phoneNumber.size() <= 20 &&
             data.loginPassword is string && data.loginPassword.size() >= 6 &&
             data.withdrawalPassword is string && data.withdrawalPassword.size() == 6; 
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && isValidId(userId);
      allow update: if isOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phoneNumber', 'loginPassword', 'withdrawalPassword']) &&
                    isValidUser(request.resource.data);
    }
  }
}
